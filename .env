.

# ── Enable / Disable Providers ────────────────────────────────────────────────
ENABLE_SERPAPI=true
ENABLE_GOOGLE_CSE=true
ENABLE_CUSTOM_PROVIDER=false
# ENABLE_GOOGLE_HTML=false (No longer required, google_html is always available)
ENABLE_BING=true
ENABLE_BRIGHTDATA=true
SEARCH_PROVIDER_PRIORITY=playwright_google,google_html,duckduckgo,brave,bing,brightdata,linkedin_playwright

# ── SerpAPI ───────────────────────────────────────────────────────────────────
SERPAPI_KEY=

# ── Bright Data ───────────────────────────────────────────────────────────────
BRIGHTDATA_KEY=712ade1a-c313-42d1-aa1d-13e8725f777c
BRIGHTDATA_ZONE=serp_api1

# ── Search Tuning ──────────────────────────────────────────────────────────────
MAX_RESULTS_PER_QUERY=20
GOOGLE_MIN_RESULTS=3

# ── Discovery Expansion ────────────────────────────────────────────────────────
TARGET_COMPANIES=50
MAX_SEARCH_PAGES=3
MAX_CRAWL_WORKERS=5

# ── Proxies ────────────────────────────────────────────────────────────────────
PROXY_FILE=proxies.txt
VERIFY_SSL=false

